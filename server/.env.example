# RAG 配置 - 复制本文件为 .env 并填写实际值

# 内网 LLM 服务（OpenAI 兼容格式）
RAG_LLM_BASE_URL=http://internal-llm:8080/v1
RAG_LLM_MODEL=qwen2.5-7b

# Embedding 服务（OpenAI /embeddings 接口）
RAG_EMBEDDING_BASE_URL=http://internal-llm:8080/v1
RAG_EMBEDDING_MODEL=bge-m3

# ReRank 服务（可选，不配置则跳过重排序）
RAG_RERANK_BASE_URL=http://internal-rerank:8080
RAG_RERANK_MODEL=bge-reranker-v2-m3

# 检索策略: vector | bm25 | hybrid（默认 hybrid）
RAG_RETRIEVAL_STRATEGY=hybrid
# RRF 融合常数（越大越倾向于保留低排名结果）
RAG_RRF_K=60

# 向量检索召回数
RAG_TOP_K=5
# ReRank 后保留数
RAG_TOP_N=3
# 低于该相似度的向量结果直接丢弃
RAG_MIN_VECTOR_SCORE=0.28
# ReRank 分数过低时拒绝作答
RAG_MIN_RERANK_SCORE=0.08
# 追问时用于改写检索问题的历史轮数
RAG_REWRITE_HISTORY_TURNS=2
# 每个 chunk 最大字符数（.md 按标题/段落切，其他按段落切）
RAG_CHUNK_SIZE=600
# 相邻 chunk 重叠字符数
RAG_CHUNK_OVERLAP=80
# 每批 Embedding 请求包含的 chunk 数（减少 API 调用次数）
RAG_EMBED_BATCH_SIZE=32
# 向量写盘保留小数位，降低索引体积与内存占用
RAG_EMBEDDING_DECIMALS=6

# RAG 网络请求健壮性
RAG_HTTP_TIMEOUT_MS=30000
RAG_HTTP_RETRIES=2
RAG_HTTP_RETRY_DELAY_MS=800

# uploads 目录自动同步扫描间隔（毫秒）
UPLOAD_SYNC_INTERVAL_MS=5000
